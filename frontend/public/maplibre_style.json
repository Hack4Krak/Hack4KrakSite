{
  "version": 8,
  "name": "Empty Style",
  "metadata": { "maputnik:renderer": "mlgljs" },
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "https://tiles.openfreemap.org/planet"
    }
  },
  "sprite": "https://tiles.openfreemap.org/sprites/ofm_f384/ofm",
  "glyphs": "https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "bg",
      "type": "background",
      "paint": { "background-color": "rgba(23, 23, 23, 1)" }
    },
    {
      "id": "Green",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["all", ["in", "subclass", "park", "wood", "forest"]],
      "layout": { "visibility": "visible" },
      "paint": {
        "fill-antialias": true,
        "fill-color": {
          "stops": [[1, "rgba(38, 38, 38, 1)"], [6, "rgba(38, 38, 38, 1)"]]
        },
        "fill-opacity": 1
      }
    },
    {
      "id": "Water",
      "type": "fill",
      "metadata": {},
      "source": "openmaptiles",
      "source-layer": "water",
      "filter": [
        "all",
        ["!=", "intermittent", 1],
        ["!=", "brunnel", "tunnel"],
        ["in", "class", "river", "lake"]
      ],
      "layout": { "visibility": "visible" },
      "paint": { "fill-color": "#759FB6" }
    },
    {
      "id": "Water way",
      "type": "line",
      "metadata": {},
      "source": "openmaptiles",
      "source-layer": "waterway",
      "filter": ["all", ["!=", "intermittent", 1], ["!=", "brunnel", "tunnel"]],
      "layout": { "visibility": "visible" },
      "paint": { "line-color": "rgba(117, 159, 182, 1)" }
    },
    {
      "id": "District border",
      "type": "line",
      "metadata": {},
      "source": "openmaptiles",
      "source-layer": "boundary",
      "minzoom": 3,
      "filter": ["all", ["in", "admin_level", 9]],
      "layout": { "line-join": "round", "visibility": "visible" },
      "paint": { "line-color": "#737373", "line-width": 1.5, "line-opacity": 1 }
    },
    {
      "id": "City border",
      "type": "line",
      "metadata": {},
      "source": "openmaptiles",
      "source-layer": "boundary",
      "minzoom": 3,
      "filter": ["all", ["in", "admin_level", 6, 7]],
      "layout": { "line-join": "round", "visibility": "visible" },
      "paint": { "line-color": "#737373", "line-width": 4 }
    }
  ],
  "id": "3o82wox"
}
